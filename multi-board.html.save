<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>SN ULTRA - COMMERCIAL FINAL LAUNCH</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root{
--bg:#030303;
--card:rgba(15,15,15,.82);
--border:rgba(255,255,255,.08);
--glow: rgba(0, 122, 255, 0.15);
}
body{
font-family:'Inter',sans-serif;
background:#030303;
color:#fff;
overflow-x:hidden;
}
.mono{font-family:'JetBrains Mono',monospace;}
.session-box{
background:var(--card);
backdrop-filter:blur(16px);
border:1px solid var(--border);
border-radius:24px;
display:flex;
flex-direction:column;
min-height:250px;
box-shadow:0 10px 40px rgba(0,0,0,.5);
position:relative;
overflow:hidden;
}
#login-overlay{
position:fixed;
inset:0;
background:rgba(0,0,0,.95);
z-index:9999;
display:flex;
justify-content:center;
align-items:center;
}
#toast-container{
position:fixed;
top:20px;
right:20px;
z-index:10000;
display:flex;
flex-direction:column;
gap:10px;
}
.toast{
padding:15px 20px;
border-radius:12px;
font-size:12px;
font-weight:bold;
border:1px solid rgba(255,255,255,.15);
backdrop-filter:blur(10px);
animation:slideIn .25s ease forwards;
}
.toast.error { background: rgba(255, 59, 48, 0.9); color: white; } 
.toast.warning { background: rgba(255, 204, 0, 0.9); color: black; } 
.toast.success { background: rgba(50, 215, 75, 0.9); color: white; }
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
.video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; border: 1px solid var(--border); }
.video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
::-webkit-scrollbar { width: 5px; } ::-webkit-scrollbar-track { background: transparent; } ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

.locked-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(5px); z-index: 10; display: flex; flex-direction: column; justify-content: center; align-items: center; }
/* แก้ไข .termux-box ให้ overflow-y: auto เพื่อให้มี scrollbar และยืดไม่เกิน 120px */
.termux-box { background: #000; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #0f0; padding: 10px; height: 120px; overflow-y: auto; border: 1px solid rgba(0,255,0,0.3); border-radius: 8px; text-align: left; }
.termux-line { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 4px; }
.pulse-dot { width:8px;height:8px;border-radius:50%; background:currentColor; animation:pulse 2s infinite; }
@keyframes pulse { 0%{opacity:1} 50%{opacity:.4} 100%{opacity:1} }

/* เพิ่ม CSS สำหรับ User Modal */
#user-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(5px); z-index: 9999; display: none; justify-content: center; align-items: center; padding: 16px; }
.modal-content { background: var(--card); border: 1px solid var(--border); border-radius: 24px; padding: 20px; width: 100%; max-width: 500px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
.modal-content input { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 10px; color: #fff; margin-bottom: 10px; outline: none; }
</style>
</head>
<body class="pb-12">

    <div id="toast-container"></div>

    <div id="login-overlay">
        <div class="bg-black/50 border border-white/10 p-8 rounded-3xl text-center max-w-sm w-full mx-4 shadow-[0_0_50px_rgba(0,122,255,0.2)]">
            <div class="w-16 h-16 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-6"><i class="fas fa-shield-alt text-white text-2xl"></i></div>
            <h2 class="text-2xl font-black italic uppercase mb-1">SN ULTRA</h2>
            <p class="text-xs text-gray-500 uppercase tracking-widest mb-6">Commercial Launch Access</p>
            <input type="text" id="admin-user" placeholder="Username (owner/admin)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white mb-3 focus:outline-none focus:border-blue-500 mono">
            <input type="password" id="admin-pass" placeholder="Password" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white mb-4 focus:outline-none focus:border-blue-500 mono">
            <button onclick="loginAdmin()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl uppercase transition">Secure Login</button>
            <p id="login-error" class="text-red-500 text-[10px] mt-4 font-bold hidden">INVALID CREDENTIALS</p>
        </div>
    </div>
    
    <div id="user-modal">
        <div class="modal-content">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-black text-blue-400">MANAGE DATABASE</h3>
                <button onclick="closeUserModal()" class="text-gray-400 hover:text-white"><i class="fas fa-times"></i></button>
            </div>
            <div class="mb-4 p-3 bg-white/5 border border-white/10 rounded-xl">
                <h4 class="text-xs text-gray-400 font-bold mb-2">ADD / UPDATE USER</h4>
                <input type="text" id="mng-user" placeholder="Username" class="mono text-sm">
                <input type="number" id="mng-credit" placeholder="Credits (CR)" class="mono text-sm">
                <button onclick="saveUser()" class="w-full bg-green-600/20 text-green-400 hover:bg-green-600 hover:text-white border border-green-500/50 rounded-lg py-2 text-xs font-bold transition">SAVE USER</button>
            </div>
            <div class="p-3 bg-red-900/20 border border-red-500/20 rounded-xl">
                 <h4 class="text-xs text-red-400 font-bold mb-2">BAN / REMOVE USER</h4>
                 <input type="text" id="mng-ban-user" placeholder="Username to Ban/Remove" class="mono text-sm border-red-500/30 focus:border-red-500">
                 <button onclick="deleteUser()" class="w-full bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white border border-red-500/50 rounded-lg py-2 text-xs font-bold transition">EXECUTE BAN</button>
            </div>
        </div>
    </div>

    <header class="max-w-[1800px] mx-auto px-4 sm:px-6 pt-8 pb-6 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
        <div>
            <p class="text-[10px] text-blue-500 font-bold uppercase mb-1">Public Commercial Platform</p>
            <h1 class="text-4xl sm:text-5xl font-black italic uppercase leading-none">SN ULTRA</h1>
        </div>
        <div class="flex gap-2 items-center flex-wrap">
            <button id="lang-btn" onclick="toggleLanguage()" class="px-3 py-2 bg-white/10 text-white rounded-xl text-[10px] font-bold hover:bg-white/20 transition">TH | EN</button>
            <span id="role-badge" class="px-3 py-1 bg-purple-500/20 text-purple-400 border border-purple-500/50 rounded text-[9px] font-bold uppercase hidden"></span>
            <div id="socket-status" class="px-4 py-2 bg-amber-500/10 text-amber-500 rounded-xl text-[10px] font-black border border-amber-500/30"><i class="fas fa-spinner fa-spin"></i> CONNECTING...</div>
            <button onclick="logoutAdmin()" class="px-4 py-2 bg-red-500/20 text-red-400 rounded-xl hover:bg-red-500/40 transition"><i class="fas fa-sign-out-alt"></i></button>
        </div>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-6 max-w-[1800px] mx-auto px-4 sm:px-6">

        <div class="session-box xl:col-span-4" style="--glow: rgba(255, 149, 0, 0.2)">
            <div class="header-box border-b border-orange-500/20 p-4 flex justify-between items-center">
                <span class="text-xs font-black text-orange-400 uppercase"><i class="fas fa-gamepad mr-2"></i>Private Game Server</span>
                <span id="gs-main-status" class="text-[10px] font-bold text-gray-500"><i class="fas fa-circle text-gray-600 mr-1"></i>SYSTEM IDLE</span>
            </div>
            <div class="p-5 grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-black/50 p-5 rounded-2xl border border-white/5 flex flex-col items-center text-center">
                    <h3 class="text-sm font-black text-white uppercase mb-1"><i class="fab fa-windows text-blue-400 mr-2"></i>Windows Engine</h3>
                    <p class="text-[10px] text-gray-500 mono mb-2">game_server_core.exe</p>
                    <span id="gs-win-status" class="px-3 py-1 bg-gray-800 text-gray-400 text-[9px] rounded-full font-bold uppercase mb-4">OFFLINE</span>
                    <div class="flex flex-row justify-center gap-3 w-full max-w-[250px]">
                        <button onclick="controlServer('win', 'start')" class="flex-1 py-3 bg-green-600/20 text-green-400 hover:bg-green-600 hover:text-white border border-green-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-play mr-1"></i> Start</button>
                        <button onclick="controlServer('win', 'stop')" class="flex-1 py-3 bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white border border-red-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-stop mr-1"></i> Stop</button>
                    </div>
                </div>
                <div class="bg-black/50 p-5 rounded-2xl border border-white/5 flex flex-col items-center text-center">
                    <h3 class="text-sm font-black text-white uppercase mb-1"><i class="fab fa-android text-green-400 mr-2"></i>Android Engine</h3>
                    <p class="text-[10px] text-gray-500 mono mb-2">api_mobile_bridge.js</p>
                    <span id="gs-and-status" class="px-3 py-1 bg-gray-800 text-gray-400 text-[9px] rounded-full font-bold uppercase mb-4">OFFLINE</span>
                    <div class="flex flex-row justify-center gap-3 w-full max-w-[250px]">
                        <button onclick="controlServer('android', 'start')" class="flex-1 py-3 bg-green-600/20 text-green-400 hover:bg-green-600 hover:text-white border border-green-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-play mr-1"></i> Start</button>
                        <button onclick="controlServer('android', 'stop')" class="flex-1 py-3 bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white border border-red-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-stop mr-1"></i> Stop</button>
                    </div>
                </div>
                <div class="bg-black/50 p-5 rounded-2xl border border-white/5 flex flex-col items-center text-center">
                    <h3 class="text-sm font-black text-white uppercase mb-1"><i class="fas fa-dragon text-purple-400 mr-2"></i>Yulgang Engine</h3>
                    <p class="text-[10px] text-gray-500 mono mb-2">yg_server_core.exe</p>
                    <span id="gs-yg-status" class="px-3 py-1 bg-gray-800 text-gray-400 text-[9px] rounded-full font-bold uppercase mb-4">OFFLINE</span>
                    <div class="flex flex-row justify-center gap-3 w-full max-w-[250px]">
                        <button onclick="controlServer('yulgang', 'start')" class="flex-1 py-3 bg-green-600/20 text-green-400 hover:bg-green-600 hover:text-white border border-green-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-play mr-1"></i> Start</button>
                        <button onclick="controlServer('yulgang', 'stop')" class="flex-1 py-3 bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white border border-red-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-stop mr-1"></i> Stop</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="session-box" style="--glow: rgba(0, 122, 255, 0.15)">
            <div class="header-box border-b border-blue-500/20 p-4"><span class="text-xs font-black text-blue-400 uppercase"><i class="fas fa-users-cog mr-2"></i>User Control</span></div>
            <div class="p-5 flex flex-col flex-1 gap-4">
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-white/5 p-3 rounded-xl text-center border border-white/5"><p class="text-[10px] text-gray-500 uppercase">Total DB Jobs</p><p id="db-total-users" class="text-2xl font-black mono text-white">0</p></div>
                    <div class="bg-blue-900/20 p-3 rounded-xl text-center border border-blue-500/20"><p class="text-[10px] text-blue-300 uppercase">Active Today</p><p id="db-active-users" class="text-2xl font-black mono text-blue-400">0</p></div>
                </div>
                <button onclick="openUserModal()" class="w-full mt-auto py-3 bg-blue-600/20 text-blue-400 hover:bg-blue-600 hover:text-white border border-blue-500/50 rounded-xl text-[10px] font-bold uppercase transition"><i class="fas fa-database mr-1"></i> Manage DB</button>
            </div>
        </div>

        <div class="session-box" style="--glow: rgba(191, 90, 242, 0.15)">
            <div class="header-box border-b border-purple-500/20 p-4"><span class="text-xs font-black text-purple-400 uppercase"><i class="fas fa-robot mr-2"></i>Engine Credits (Live DB)</span></div>
            <div class="p-5 flex flex-col justify-center gap-4">
                <div class="flex justify-between text-xs font-bold bg-white/5 p-2 rounded border border-white/5"><span class="text-white">RunwayML</span><span id="cr-runway" class="text-purple-400 mono">Live Sync...</span></div>
                <div class="flex justify-between text-xs font-bold bg-white/5 p-2 rounded border border-white/5"><span class="text-white">Replicate</span><span id="cr-replicate" class="text-green-400 mono">Live Sync...</span></div>
                <div class="flex justify-between text-xs font-bold bg-white/5 p-2 rounded border border-white/5"><span class="text-white">Gemini</span><span id="cr-gemini" class="text-blue-400 mono">Live Sync...</span></div>
                <div class="flex justify-between text-xs font-bold bg-white/5 p-2 rounded border border-white/5"><span class="text-white">ElevenLabs</span><span id="cr-eleven" class="text-red-400 mono">Live Sync...</span></div>
            </div>
        </div>

        <div class="session-box" style="--glow: rgba(255, 255, 255, 0.1)">
            <div class="header-box border-b border-gray-500/20 p-4"><span class="text-xs font-black text-gray-300 uppercase"><i class="fas fa-file-invoice-dollar mr-2"></i>Credit Policy</span></div>
            <div class="p-5 flex flex-col justify-center gap-3 text-[10px] font-bold">
                <div class="bg-black/50 border border-white/10 rounded-lg p-3 text-center">
                    <p class="text-gray-400 mb-1">Base Rate</p>
                    <p class="text-lg text-white mono">1 THB = 100 CR</p>
                </div>
                <div class="flex justify-between bg-white/5 p-2 rounded border border-white/5"><span class="text-white">Topup >= 100 THB</span><span class="text-green-400 mono">+10% BONUS</span></div>
                <div class="flex justify-between bg-white/5 p-2 rounded border border-white/5"><span class="text-white">Topup >= 300 THB</span><span class="text-green-400 mono">+20% BONUS</span></div>
                <div class="flex justify-between bg-white/5 p-2 rounded border border-white/5"><span class="text-white">Topup >= 1000 THB</span><span class="text-green-400 mono">+30% BONUS</span></div>
            </div>
        </div>

        <div class="session-box" style="--glow: rgba(255, 204, 0, 0.15)">
            <div class="header-box border-b border-amber-500/20 p-4"><span class="text-xs font-black text-amber-400 uppercase"><i class="fas fa-coins mr-2"></i>Faucet Termux Bot</span></div>
            
            <div id="faucet-locked" class="locked-overlay rounded-b-2xl">
                <i class="fas fa-lock text-3xl text-amber-500 mb-2"></i>
                <p class="text-[10px] font-bold text-gray-300 uppercase mb-4 text-center px-4">Register to run<br>Termux Auto-Faucet</p>
                <button onclick="registerFaucet()" class="bg-amber-500 hover:bg-amber-400 text-black px-6 py-2 rounded-xl text-xs font-black uppercase transition shadow-[0_0_15px_rgba(255,204,0,0.4)]">Initialize Script</button>
            </div>

            <div class="p-4 flex flex-col justify-between h-full gap-3 filter blur-sm transition duration-300" id="faucet-content">
                <div class="flex justify-between items-center bg-black/50 p-2 rounded border border-amber-500/20">
                    <div><p class="text-[9px] text-gray-500 uppercase">Total Earned</p><p class="text-xl font-black mono text-amber-400"><span id="faucet-dispensed">0.00000</span> <span class="text-[10px]">USDT</span></p></div>
                    <div class="text-right"><p class="text-[9px] text-gray-500 uppercase">Status</p><p class="text-[10px] text-green-400 font-bold pulse-dot"><i class="fas fa-circle text-[8px]"></i> FARMING</p></div>
                </div>
                <div id="termux-console" class="termux-box flex-1">
                    <div class="text-gray-500 termux-line">root@sn-server:~# ./faucet_bot.sh</div>
                    <div class="text-cyan-400 termux-line">[SYS] Connecting pool...</div>
                </div>
            </div>
        </div>

        <div class="session-box xl:col-span-2" style="--glow: rgba(50, 215, 75, 0.15)">
            <div class="header-box border-b border-cyan-500/20 p-4 flex justify-between items-center">
                <span id="bot-title" class="text-xs font-black text-cyan-400 uppercase"><i class="fab fa-telegram-plane mr-2"></i>Hamster Bot & Termux Key</span>
            </div>
            <div class="p-5 flex flex-col sm:flex-row gap-5">
                <div class="flex-1 video-container shadow-lg border border-cyan-500/30 bg-black">
                    <div id="yt-player-div" class="absolute top-0 left-0 w-full h-full"></div>
                </div>
                <div class="flex-1 flex flex-col justify-between gap-4">
                    <div>
                        <p id="lbl-api-key" class="text-[10px] text-gray-400 uppercase font-bold mb-1">Termux API Key (12H Validity)</p>
                        <div class="flex gap-2 relative">
                            <input type="text" id="termux-key" readonly value="WATCH FULL VIDEO TO UNLOCK"class="w-full bg-black/80 p-3 rounded-lg text-xs mono text-gray-500 border border-white/10 text-center focus:outline-none transition-all">
                            <button onclick="copyKey()" class="bg-cyan-600/20 hover:bg-cyan-500 text-cyan-400 hover:text-white border border-cyan-500/30 px-4 rounded-lg transition"><i class="fas fa-copy"></i></button>
                        </div>
                        <button id="btn-unlock" onclick="processKeyUnlock()" class="w-full mt-2 bg-red-600 hover:bg-red-500 text-white font-bold py-2 rounded-lg text-[10px] uppercase transition shadow-lg flex items-center justify-center gap-2">
                            <i class="fab fa-youtube text-sm"></i> <span id="txt-unlock">Generate Key</span>
                        </button>
                        <p id="key-timer" class="text-[9px] text-amber-500 font-bold text-center mt-2 hidden">Key expires in: <span id="time-left">12:00:00</span></p>
                    </div>
                    <div class="grid grid-cols-2 gap-2 mt-2">
                        <button id="btn-99" class="bg-white/5 hover:bg-cyan-500/20 border border-white/10 hover:border-cyan-500/

