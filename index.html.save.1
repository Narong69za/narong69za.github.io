    <script>
        const API_BASE = "https://api.sn-designstudio.dev";

        // 1. TEMPLATE REDIRECT
        document.querySelectorAll("[data-template]").forEach(el => {
            el.addEventListener("click", () => {
                const model = el.dataset.template;
                if (model) window.location.href = "create.html?template=" + model;
            });
        });

        // 2. PM2 REAL-TIME SYNC
        async function syncUltraSystem() {
            try {
                const response = await fetch(`${API_BASE}/api/admin/realtime-status`);
                const data = await response.json();

                if (data.success && data.services) {
                    const listDisplay = document.getElementById("pm2-list-display");
                    const serverStatus = document.getElementById("server-status");

                    const masterProc = data.services.find(s => s.name.includes('api'));
                    if (serverStatus) serverStatus.innerText = masterProc && masterProc.status === 'online' ? "ULTRA ONLINE" : "OFFLINE";

                    if (listDisplay) {
                        listDisplay.innerHTML = data.services.map(proc => {
                            const isOnline = proc.status === 'online';
                            const statusClass = isOnline ? 'glow-green' : 'glow-red';
                            const dotClass = isOnline ? '' : 'dot-red';
                            const uptimeMin = Math.floor(proc.uptime / 60000);
                            const uptimeText = uptimeMin > 60 ? Math.floor(uptimeMin/60) + "h" : uptimeMin + "m";

                            return `
                                <div class="service-row">
                                    <div>
                                        <span class="service-name">${proc.name.toUpperCase()}</span>
                                        <span class="service-meta">RESTARTS: ${proc.restarts}</span>
                                    </div>
                                    <div style="text-align:center; color:#888; font-size:11px;">${proc.cpu}%</div>
                                    <div style="text-align:center; color:#888; font-size:11px;">${proc.memory}M</div>
                                    <div style="text-align:center; color:#555; font-size:11px;">${uptimeText}</div>
                                    <div style="display:flex; justify-content:center; align-items:center; gap:8px;" class="${statusClass}">
                                        <span class="dot ${dotClass}" style="width:6px; height:6px;"></span>
                                        <span style="font-size:10px;">${isOnline ? 'RUNNING' : 'STOPPED'}</span>
                                    </div>
                                </div>`;
                        }).join('');
                    }
                }
            } catch (err) {
                if(document.getElementById("server-status")) document.getElementById("server-status").innerText = "OFFLINE";
            }
        }

        // 3. NETWORK GRAPH (CAMELCASE FIXED)
        const canvas = document.getElementById('network-graph-canvas');
        const ctx = canvas.getContext('2d');
        let graphHistory = new Array(50).fill(0);

        function drawGraph() {
            if (!ctx) return;
            const w = canvas.width;
            const h = canvas.height;
            graphHistory.push(20 + Math.random() * 60);
            graphHistory.shift();

            ctx.clearRect(0, 0, w, h);
            ctx.beginPath();
            ctx.lineWidth = 1.5;
            ctx.strokeStyle = '#00ffd5';
            ctx.shadowBlur = 10;
            ctx.shadowColor = 'rgba(0, 255, 213, 0.5)';

            const step = w / 49;
            for (let i = 0; i < graphHistory.length; i++) {
                const x = i * step;
                const y = h - (graphHistory[i] / 100 * h);
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
            requestAnimationFrame(drawGraph);
        }

        function resize() { canvas.width = canvas.parentElement.offsetWidth; canvas.height = 60; }
        window.addEventListener('resize', resize);
        resize();
        drawGraph();
        setInterval(syncUltraSystem, 4000);
        syncUltraSystem();
    </script>
