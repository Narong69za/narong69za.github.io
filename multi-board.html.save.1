<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SN ULTRA - COMMERCIAL FINAL LAUNCH</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/dashboard.css">
</head>
<body class="pb-12 bg-[#030303]">
    <div id="toast-container" class="fixed top-4 right-4 z-[99999] flex flex-col gap-2"></div>

    <div id="user-modal" style="display:none;" class="fixed inset-0 bg-black/85 backdrop-blur-sm z-[9999] justify-center items-center p-4">
        <div class="bg-[#0f0f0f] border border-white/10 rounded-3xl p-6 w-full max-w-md shadow-2xl">
            <div class="flex justify-between mb-4"><h3 class="text-blue-400 font-black uppercase"><i class="fas fa-database mr-2"></i>Manage DB</h3><button onclick="closeUserModal()" class="text-gray-400 hover:text-white"><i class="fas fa-times"></i></button></div>
            <div class="mb-4">
                <input id="mng-user" placeholder="User ID" class="w-full bg-white/5 border border-white/10 rounded-lg p-3 mb-2 outline-none text-white">
                <input type="number" id="mng-credit" placeholder="Credits" class="w-full bg-white/5 border border-white/10 rounded-lg p-3 mb-2 outline-none text-white">
                <button onclick="saveUser()" id="btn-save-user" class="w-full bg-green-600/20 text-green-400 border border-green-500/50 py-3 rounded-lg font-bold hover:bg-green-600 hover:text-white transition uppercase">Save Changes</button>
            </div>
            <div>
                <input id="mng-ban-user" placeholder="User to Ban" class="w-full bg-red-500/10 border border-red-500/30 rounded-lg p-3 mb-2 outline-none text-white">
                <button onclick="deleteUser()" id="btn-delete-user" class="w-full bg-red-600/20 text-red-400 border border-red-500/50 py-3 rounded-lg font-bold hover:bg-red-600 hover:text-white transition uppercase">Ban User</button>
            </div>
        </div>
    </div>

    <div id="login-overlay" class="fixed inset-0 bg-black/95 z-[9999] flex justify-center items-center p-4">
        <div class="bg-[#0a0a0a] border border-white/10 p-8 rounded-3xl text-center w-full max-w-sm shadow-[0_0_40px_rgba(0,122,255,0.15)]">
            <div class="w-16 h-16 bg-blue-600 rounded-full mx-auto flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(37,99,235,0.4)]"><i class="fas fa-shield-alt text-white text-2xl"></i></div>
            <h2 class="text-3xl font-black text-white mb-1 italic">SN ULTRA</h2>
            <p class="text-[10px] text-gray-500 uppercase tracking-[0.2em] mb-8 font-bold">Secure Terminal Access</p>
            <input id="admin-user" type="text" placeholder="Username" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 mb-3 text-white outline-none focus:border-blue-500/50 transition-all font-bold">
            <input id="admin-pass" type="password" placeholder="Password" class="w-full bg-white/5 border border-white/10 rounded-xl p-4 mb-6 text-white outline-none focus:border-blue-500/50 transition-all font-bold">
            <button id="btn-login" onclick="loginAdmin()" class="w-full bg-blue-600 text-white font-black py-4 rounded-xl hover:bg-blue-500 shadow-lg shadow-blue-900/20 transition-all uppercase tracking-widest">Secure Login</button>
            <p id="login-error" class="text-red-500 text-[10px] mt-6 font-bold hidden bg-red-500/10 py-2 rounded-lg border border-red-500/20"></p>
        </div>
    </div>

    <header class="max-w-[1800px] mx-auto px-4 sm:px-6 pt-10 pb-8 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6">
        <div>
            <p class="text-[10px] text-blue-500 font-black uppercase tracking-[0.3em] mb-2">Commercial Final Launch</p>
            <h1 class="text-5xl font-black italic text-white tracking-tighter">SN ULTRA</h1>
        </div>
        <div class="flex gap-3 flex-wrap items-center">
            <span id="role-badge" class="px-4 py-1.5 bg-purple-500/10 border border-purple-500/30 text-purple-400 rounded-lg text-[10px] font-black hidden uppercase tracking-widest"></span>
            <div id="socket-status" class="px-5 py-2 bg-amber-500/5 border border-amber-500/20 text-amber-500 rounded-2xl text-[10px] font-black uppercase tracking-widest flex items-center"><i class="fas fa-spinner fa-spin mr-2"></i> Connecting System...</div>
            <button onclick="logoutAdmin()" class="w-10 h-10 flex items-center justify-center bg-red-500/10 border border-red-500/20 text-red-400 rounded-xl hover:bg-red-500 hover:text-white transition-all"><i class="fas fa-power-off"></i></button>
        </div>
    </header>
    <main class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-6 max-w-[1800px] mx-auto px-4 pb-12">
        
        <div class="session-box xl:col-span-4 p-6 sm:p-8" style="--glow: rgba(255, 149, 0, 0.1)">
            <div class="text-orange-400 font-black mb-6 flex items-center text-xs tracking-[0.2em] border-b border-orange-500/20 pb-4 uppercase"><i class="fas fa-microchip mr-3"></i>Engine Management</div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center bg-black/40 p-6 rounded-2xl border border-white/5 relative">
                    <div class="text-xs font-black text-white/60 mb-3 uppercase tracking-widest"><i class="fab fa-windows text-blue-400 mr-2"></i>Windows Engine</div>
                    <div id="gs-win-status" class="text-gray-500 text-[9px] font-black tracking-widest bg-gray-800/50 rounded-full inline-block px-4 py-1.5 mb-6 uppercase">System Idle</div>
                    <div class="flex gap-2"><button onclick="controlServer('win','start')" class="flex-1 bg-green-500/10 text-green-400 border border-green-500/20 py-2.5 rounded-xl text-[10px] font-black hover:bg-green-500 transition-all">START</button><button onclick="controlServer('win','stop')" class="flex-1 bg-red-500/10 text-red-400 border border-red-500/20 py-2.5 rounded-xl text-[10px] font-black hover:bg-red-500 transition-all">STOP</button></div>
                </div>
                <div class="text-center bg-black/40 p-6 rounded-2xl border border-white/5 relative">
                    <div class="text-xs font-black text-white/60 mb-3 uppercase tracking-widest"><i class="fab fa-android text-green-400 mr-2"></i>Android Engine</div>
                    <div id="gs-and-status" class="text-gray-500 text-[9px] font-black tracking-widest bg-gray-800/50 rounded-full inline-block px-4 py-1.5 mb-6 uppercase">System Idle</div>
                    <div class="flex gap-2"><button onclick="controlServer('android','start')" class="flex-1 bg-green-500/10 text-green-400 border border-green-500/20 py-2.5 rounded-xl text-[10px] font-black hover:bg-green-500 transition-all">START</button><button onclick="controlServer('android','stop')" class="flex-1 bg-red-500/10 text-red-400 borde
