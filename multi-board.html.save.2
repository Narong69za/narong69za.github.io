    <script>
        tailwind.config = {
          theme: {
            extend: {
              colors: { 'yg-green': '#22c55e', 'ran-red': '#ef4444', 'sn-gold': '#f59e0b' },
              animation: { 'ticker': 'ticker 25s linear infinite' },
